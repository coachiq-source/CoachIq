# ======================================================================
# Required (these 5 match the Railway Shared Variables)
# ======================================================================

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# GitHub — single combined "owner/repo" value (parsed at startup)
GITHUB_TOKEN=ghp_...                       # PAT w/ Contents: RW on target repo
GITHUB_REPO=coachiq-source/CoachIq

# Resend
RESEND_API_KEY=re_...
COACH_EMAIL_FROM=johnmaxwell.kelly@gmail.com

# ======================================================================
# Optional
# ======================================================================

# Claude model + token cap (defaults shown)
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=16000

# Target branch + public base URL. If PUBLIC_BASE_URL is not set, it's
# derived as https://<owner>.github.io/<repo> from GITHUB_REPO.
GITHUB_BRANCH=main
# PUBLIC_BASE_URL=https://coachiq-source.github.io/CoachIq

# Shared secret for Formspree auth. If unset, auth is SKIPPED (Session 1
# posture — harden before production).
# WEBHOOK_SECRET=change-me-long-random-string

# Optional reply-to header for coach emails
# EMAIL_REPLY_TO=johnmaxwell.kelly@gmail.com

# Where pipeline-failure alerts go (default: johnmaxwell.kelly@gmail.com)
# OPS_NOTIFY_EMAIL=johnmaxwell.kelly@gmail.com

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
SYSTEM_PROMPT_PATH=firstwhistle_master_system_prompt.md
